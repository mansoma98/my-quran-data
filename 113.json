{
    "surah_name": "الفَلَقِ",
    "surah_number": 113,
    "ayahs": [
        {
            "ayah_number": "١",
            "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ قُلۡ أَعُوذُ بِرَبِّ ٱلۡفَلَقِ"
        },
        {
            "ayah_number": "٢",
            "text": "مِن شَرِّ مَا خَلَقَ"
        },
        {
            "ayah_number": "٣",
            "text": "وَمِن شَرِّ  غَاسِقٍ إِذَا وَقَبَ"
        },
        {
            "ayah_number": "٤",
            "text": "وَمِن شَرِّ ٱلنَّفَّـٰثَٰتِ فِي ٱلۡعُقَدِ"
        },
        {
            "ayah_number": "٥",
            "text": "وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ"
        }
    ]
}