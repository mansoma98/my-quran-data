{
    "surah_name": "الكَوۡثَرِ",
    "surah_number": 108,
    "ayahs": [
        {
            "ayah_number": "١",
            "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ إِنَّآ أَعۡطَيۡنَٰكَ ٱلۡكَوۡثَرَ"
        },
        {
            "ayah_number": "٢",
            "text": "فَصَلِّ لِرَبِّكَ وَٱنۡحَرۡ"
        },
        {
            "ayah_number": "٣",
            "text": "إِنَّ شَانِئَكَ هُوَ ٱلۡأَبۡتَرُ"
        }
    ]
}