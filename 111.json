{
    "surah_name": "المَسَدِ",
    "surah_number": 111,
    "ayahs": [
        {
            "ayah_number": "١",
            "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ تَبَّتۡ يَدَآ أَبِي لَهَبٖ وَتَبَّ"
        },
        {
            "ayah_number": "٢",
            "text": "مَآ أَغۡنَىٰ عَنۡهُ مَالُهُۥ وَمَا كَسَبَ"
        },
        {
            "ayah_number": "٣",
            "text": "سَيَصۡلَىٰ نَارٗا ذَاتَ لَهَبٖ"
        },
        {
            "ayah_number": "٤",
            "text": "وَٱمۡرَأَتُهُۥ حَمَّالَةَ ٱلۡحَطَبِ"
        },
        {
            "ayah_number": "٥",
            "text": "فِي جِيدِهَا حَبۡلٞ مِّن مَّسَدِۭ"
        }
    ]
}