{
    "surah_name": "الكَافِرُونَ",
    "surah_number": 109,
    "ayahs": [
        {
            "ayah_number": "١",
            "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ قُلۡ يَـٰٓأَيُّهَا ٱلۡكَٰفِرُونَ"
        },
        {
            "ayah_number": "٢",
            "text": "لَآ أَعۡبُدُ مَا تَعۡبُدُونَ"
        },
        {
            "ayah_number": "٣",
            "text": "وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ"
        },
        {
            "ayah_number": "٤",
            "text": "وَلَآ أَنَا۠ عَابِدٞ مَّا عَبَدتُّمۡ"
        },
        {
            "ayah_number": "٥",
            "text": "وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ"
        },
        {
            "ayah_number": "٦",
            "text": "لَكُمۡ دِينُكُمۡ وَلِيَ دِينِ"
        }
    ]
}