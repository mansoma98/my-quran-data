{
    "surah_name": "النَّاسِ",
    "surah_number": 114,
    "ayahs": [
        {
            "ayah_number": "١",
            "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ قُلۡ أَعُوذُ بِرَبِّ ٱلنَّاسِ"
        },
        {
            "ayah_number": "٢",
            "text": "مَلِكِ ٱلنَّاسِ"
        },
        {
            "ayah_number": "٣",
            "text": "إِلَٰهِ  ٱلنَّاسِ"
        },
        {
            "ayah_number": "٤",
            "text": "مِن شَرِّ ٱلۡوَسۡوَاسِ ٱلۡخَنَّاسِ"
        },
        {
            "ayah_number": "٥",
            "text": "ٱلَّذِي  يُوَسۡوِسُ فِي صُدُورِ ٱلنَّاسِ"
        },
        {
            "ayah_number": "٦",
            "text": "مِنَ ٱلۡجِنَّةِ وَٱلنَّاسِ"
        }
    ]
}