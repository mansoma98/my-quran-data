{
    "surah_name": "الإِخۡلَاصِ",
    "surah_number": 112,
    "ayahs": [
        {
            "ayah_number": "١",
            "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ قُلۡ هُوَ ٱللَّهُ أَحَدٌ"
        },
        {
            "ayah_number": "٢",
            "text": "ٱللَّهُ ٱلصَّمَدُ"
        },
        {
            "ayah_number": "٣",
            "text": "لَمۡ يَلِدۡ وَلَمۡ يُولَدۡ"
        },
        {
            "ayah_number": "٤",
            "text": "وَلَمۡ يَكُن لَّهُۥ كُفُوًا أَحَدُۢ"
        }
    ]
}