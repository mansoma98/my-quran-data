{
    "surah_name": "الفِيلِ",
    "surah_number": 105,
    "ayahs": [
        {
            "ayah_number": "١",
            "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ أَلَمۡ تَرَ كَيۡفَ فَعَلَ رَبُّكَ بِأَصۡحَٰبِ ٱلۡفِيلِ"
        },
        {
            "ayah_number": "٢",
            "text": "أَلَمۡ يَجۡعَلۡ  كَيۡدَهُمۡ فِي تَضۡلِيلٖ"
        },
        {
            "ayah_number": "٣",
            "text": "وَأَرۡسَلَ عَلَيۡهِمۡ طَيۡرًا أَبَابِيلَ"
        },
        {
            "ayah_number": "٤",
            "text": "تَرۡمِيهِم بِحِجَارَةٖ مِّن سِجِّيلٖ"
        },
        {
            "ayah_number": "٥",
            "text": "فَجَعَلَهُمۡ كَعَصۡفٖ مَّأۡكُولِۭ"
        }
    ]
}